<Window x:Class="MatrackSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctl="clr-namespace:MatrackSim.App.Controls"
        Title="Matrack Truck Sim" Height="1010" Width="1500"
        MinHeight="680" MinWidth="1000"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="#FF08090B" Foreground="{StaticResource Text}" TextElement.Foreground="{StaticResource Text}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />

        <!-- Section label -->
        <Style x:Key="Sec" TargetType="TextBlock" BasedOn="{StaticResource SectionLabel}" />

        <!-- ENGINE/AUTO toggle chip (tint supplied via Tag) -->
        <Style x:Key="Chip" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource Rounded}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <!-- faint tint wash when ON (Mac ToggleChip uses tint.opacity(0.14), NOT a solid fill) -->
                            <Border x:Name="wash" CornerRadius="11"
                                    Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Opacity="0" />
                            <Border x:Name="bd" CornerRadius="11" BorderThickness="1"
                                    Background="#66080A0E" BorderBrush="{StaticResource Stroke}" Padding="12,11">
                                <DockPanel>
                                    <Ellipse x:Name="dot" Width="8" Height="8" DockPanel.Dock="Right"
                                             VerticalAlignment="Center" Fill="{StaticResource Dimmer}" />
                                    <TextBlock x:Name="lbl" Text="{TemplateBinding Content}" Foreground="{StaticResource Dim}"
                                               FontWeight="Bold" FontSize="12" />
                                </DockPanel>
                            </Border>
                            <!-- soft tint border when ON (Mac chip strokes at tint.opacity(0.6)) -->
                            <Border x:Name="line" CornerRadius="11" BorderThickness="1" Opacity="0" IsHitTestVisible="False"
                                    BorderBrush="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="wash" Property="Opacity" Value="0.16" />
                                <Setter TargetName="bd" Property="Background" Value="Transparent" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="Transparent" />
                                <Setter TargetName="line" Property="Opacity" Value="0.6" />
                                <Setter TargetName="lbl" Property="Foreground" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                                <Setter TargetName="dot" Property="Fill" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header pill text -->
        <Style x:Key="MonoDim" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Mono}" />
            <Setter Property="Foreground" Value="{StaticResource Dim}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Cinematic power-on reveal: the cockpit fades + rises in on launch (mirrors the Mac panelReveal). -->
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Stage" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" />
                        <DoubleAnimation Storyboard.TargetName="StageT" Storyboard.TargetProperty="Y" From="22" To="0" Duration="0:0:0.6">
                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
        <!-- ===== Background (fills the window) ===== -->
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF101217" Offset="0" />
                    <GradientStop Color="#FF08090B" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Ellipse Opacity="0.07" HorizontalAlignment="Center" VerticalAlignment="Center" Width="1440" Height="1440">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#6FD3FF" Offset="0" />
                        <GradientStop Color="#006FD3FF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- ===== Cluster face, laid out at the Mac design size (16:10-ish laptop aspect) and scaled to fit ===== -->
        <Viewbox x:Name="Stage" Stretch="Uniform" Opacity="0">
            <Viewbox.RenderTransform>
                <TranslateTransform x:Name="StageT" Y="22" />
            </Viewbox.RenderTransform>
            <Grid Width="1560" Height="1120" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ================= TOP RAIL ================= -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ctl:HaulLogo Size="30" />
                        <TextBlock Text="MATRACK" FontSize="16" FontWeight="Black" Margin="14,0,0,0"
                                   VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                        <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ClockText}" FontFamily="{StaticResource Mono}" FontSize="15"
                                       FontWeight="SemiBold" Foreground="{StaticResource Text}" />
                            <TextBlock Text="{Binding TempText}" Margin="8,0,0,0" FontSize="12"
                                       Foreground="{StaticResource Dim}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- SIMULATOR badge -->
                        <Border CornerRadius="14" Background="#2EF5A623" BorderBrush="#80F5A623" BorderThickness="1"
                                Padding="13,8" Margin="0,0,10,0">
                            <TextBlock Text="⚠ SIMULATOR · TEST ONLY" FontSize="11" FontWeight="Black"
                                       Foreground="{StaticResource Amber}" />
                        </Border>
                        <!-- VIN chip (editable; border lights ice when focused) -->
                        <Border CornerRadius="14" Background="{StaticResource PanelGlass}"
                                BorderThickness="1" Padding="12,6" Margin="0,0,10,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource Stroke}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#996FD3FF" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding Vin, UpdateSourceTrigger=PropertyChanged}" Width="180"
                                         Background="Transparent" BorderThickness="0" Foreground="{StaticResource Text}"
                                         FontFamily="{StaticResource Mono}" FontSize="13" FontWeight="Bold"
                                         VerticalContentAlignment="Center" CaretBrush="{StaticResource Ice}" />
                                <TextBlock Text="{Binding VinBadge}" Foreground="{Binding VinBadgeBrush}" FontSize="8"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <!-- Status pill -->
                        <Border CornerRadius="14" Background="#220A0E14" BorderBrush="{Binding StatusBrush}" BorderThickness="1"
                                Padding="13,8">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <ScaleTransform x:Name="pulse" ScaleX="1" ScaleY="1" />
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="pulse" Storyboard.TargetProperty="ScaleX" From="0.9" To="1.25" Duration="0:0:1">
                                                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetName="pulse" Storyboard.TargetProperty="ScaleY" From="0.9" To="1.25" Duration="0:0:1">
                                                        <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource Text}" FontSize="12"
                                           FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ================= MAIN BODY — three independent columns (mirrors Mac clusterFace) ================= -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="392" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="392" />
                    </Grid.ColumnDefinitions>

                    <!-- ===== LEFT COLUMN: speed dial → gear → ROUTE → DRIVE ===== -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Speed gauge (negative bottom margin reclaims the dial's open bottom, like Mac) -->
                        <ctl:DialGauge Grid.Row="0" Mode="Speed" Width="286" Height="286" HorizontalAlignment="Center" Margin="0,0,0,-24"
                                       Fraction="{Binding SpeedFraction}" CenterText="{Binding SpeedCenterText}" Unit="KM/H" />
                        <!-- Gear -->
                        <ctl:GearIndicator Grid.Row="1" Gear="{Binding GearValue}" HorizontalAlignment="Center" Margin="0,6,0,14" />

                        <!-- ROUTE · NAVIGATION panel (moves here, above DRIVE) -->
                        <ctl:Card Grid.Row="2" Title="ROUTE · NAVIGATION" Glyph="&#xE707;" Tint="{StaticResource Ice}" Margin="0,0,0,14">
                            <StackPanel>
                                <!-- From → To on ONE row (two fields + arrow), mirrors Mac RoutePanel -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="10" Background="#73080A0E" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="10,8">
                                        <DockPanel>
                                            <!-- green origin marker (Mac smallcircle.filled.circle) -->
                                            <Grid DockPanel.Dock="Left" Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse Stroke="{StaticResource Green}" StrokeThickness="2" />
                                                <Ellipse Width="5" Height="5" Fill="{StaticResource Green}" />
                                            </Grid>
                                            <TextBox Text="{Binding RouteFrom, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource Text}" FontFamily="{StaticResource Rounded}" FontSize="12"
                                                     VerticalContentAlignment="Center" CaretBrush="{StaticResource Ice}" />
                                        </DockPanel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="→" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Dim}"
                                               VerticalAlignment="Center" Margin="7,0,7,0" />
                                    <Border Grid.Column="2" CornerRadius="10" Background="#73080A0E" BorderBrush="{StaticResource Stroke}" BorderThickness="1" Padding="10,8">
                                        <DockPanel>
                                            <!-- red destination pin (Mac mappin.circle.fill) -->
                                            <Ellipse DockPanel.Dock="Left" Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center"
                                                     Fill="{StaticResource Red}" />
                                            <TextBox Text="{Binding RouteTo, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0"
                                                     Foreground="{StaticResource Text}" FontFamily="{StaticResource Rounded}" FontSize="12"
                                                     VerticalContentAlignment="Center" CaretBrush="{StaticResource Ice}" />
                                        </DockPanel>
                                    </Border>
                                </Grid>
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Button Content="🗺 PLAN" Style="{StaticResource NeonButton}" Click="Plan_Click" Margin="0,0,8,0" />
                                    <Button Content="⤨ RANDOM" Style="{StaticResource NeonButton}" Foreground="{StaticResource Amber}" Click="Random_Click" />
                                </UniformGrid>
                                <TextBlock Text="{Binding RouteInfo}" FontSize="11" Foreground="{StaticResource Dim}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                <!-- DRIVE ROUTE + DRIVE MY DAY paired on one row (Mac RoutePanel) -->
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <Button x:Name="DriveRouteButton" Click="DriveRoute_Click" Margin="0,0,8,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                                <Setter Property="Content" Value="▶ DRIVE" />
                                                <Setter Property="Foreground" Value="{StaticResource Green}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasRouteValue}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource Green}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Green}" />
                                                        <Setter Property="Foreground" Value="#FF08090B" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DrivingRoute}" Value="True">
                                                        <Setter Property="Content" Value="■ STOP" />
                                                        <Setter Property="Background" Value="{StaticResource Red}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Red}" />
                                                        <Setter Property="Foreground" Value="#FF08090B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button x:Name="DayButton" Click="DriveMyDay_Click">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                                <Setter Property="Content" Value="☀ DRIVE MY DAY" />
                                                <Setter Property="Foreground" Value="{StaticResource Amber}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DayDriving}" Value="True">
                                                        <Setter Property="Content" Value="■ END DAY" />
                                                        <Setter Property="Background" Value="{StaticResource Amber}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Amber}" />
                                                        <Setter Property="Foreground" Value="#FF08090B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </UniformGrid>
                                <StackPanel Visibility="{Binding RouteProgressVisible, Converter={StaticResource BoolVis}}">
                                    <ctl:SegmentedProgress Height="6" Progress="{Binding RouteProgress, Mode=OneWay}" />
                                    <DockPanel Margin="0,6,0,0">
                                        <TextBlock Text="{Binding RouteProgressPercentText}" FontSize="11" Foreground="{StaticResource Dim}" />
                                        <TextBlock Text="{Binding RouteMilesLeftText}" HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Ice}" />
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </ctl:Card>

                        <!-- DRIVE panel (MODE folded into the SPEED row, mirrors Mac DrivePanel) -->
                        <ctl:Card Grid.Row="3" Title="DRIVE" Glyph="&#xE7E8;" Tint="{StaticResource Green}">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton Grid.Column="0" Style="{StaticResource Chip}" Content="⏻ ENGINE"
                                                  Tag="{StaticResource Green}" IsChecked="{Binding IgnitionOn, Mode=OneWay}"
                                                  Click="Engine_Click" />
                                    <ToggleButton Grid.Column="2" Style="{StaticResource Chip}" Content="✦ AUTO"
                                                  Tag="{StaticResource Red}" IsChecked="{Binding AutoDrive, Mode=OneWay}"
                                                  Click="Auto_Click" />
                                </Grid>
                                <TextBlock Text="QUICK SET · KM/H" Style="{StaticResource Sec}" Margin="0,0,0,6" />
                                <UniformGrid Columns="4" Margin="0,0,0,10">
                                    <ToggleButton Content="STOP" Style="{StaticResource NeonToggle}" Tag="{StaticResource Red}"
                                                  CommandParameter="0" IsChecked="{Binding ActiveSpeedStop, Mode=OneWay}" Click="SpeedPreset_Click" Margin="0,0,8,0" />
                                    <ToggleButton Content="60" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}"
                                                  CommandParameter="60" IsChecked="{Binding ActiveSpeed60, Mode=OneWay}" Click="SpeedPreset_Click" Margin="0,0,8,0" />
                                    <ToggleButton Content="90" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}"
                                                  CommandParameter="90" IsChecked="{Binding ActiveSpeed90, Mode=OneWay}" Click="SpeedPreset_Click" Margin="0,0,8,0" />
                                    <ToggleButton Content="110" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}"
                                                  CommandParameter="110" IsChecked="{Binding ActiveSpeed110, Mode=OneWay}" Click="SpeedPreset_Click" />
                                </UniformGrid>
                                <!-- SPEED label + live MODE badge + value on one line (mode no longer has its own row) -->
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock Text="SPEED" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ModeText}" Margin="8,0,0,0" FontSize="10" FontWeight="Black"
                                               Foreground="{Binding ModeBrush}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding SpeedKmhText}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Ice}" />
                                        <TextBlock Text=" km/h" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Dim}"
                                                   VerticalAlignment="Bottom" Margin="0,0,0,3" />
                                    </StackPanel>
                                </DockPanel>
                                <Slider Minimum="0" Maximum="130" Value="{Binding SpeedKmh, Mode=TwoWay}" />
                                <TextBlock Text="SIM SPEED · MAP PACE" Style="{StaticResource Sec}" Margin="0,10,0,6" />
                                <UniformGrid Columns="5">
                                    <ToggleButton Content="1×" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="1" IsChecked="{Binding ActiveT1, Mode=OneWay}" Click="TimeScale_Click" Margin="0,0,6,0" />
                                    <ToggleButton Content="5×" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="5" IsChecked="{Binding ActiveT5, Mode=OneWay}" Click="TimeScale_Click" Margin="0,0,6,0" />
                                    <ToggleButton Content="10×" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="10" IsChecked="{Binding ActiveT10, Mode=OneWay}" Click="TimeScale_Click" Margin="0,0,6,0" />
                                    <ToggleButton Content="25×" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="25" IsChecked="{Binding ActiveT25, Mode=OneWay}" Click="TimeScale_Click" Margin="0,0,6,0" />
                                    <ToggleButton Content="30×" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="30" IsChecked="{Binding ActiveT30, Mode=OneWay}" Click="TimeScale_Click" />
                                </UniformGrid>
                            </StackPanel>
                        </ctl:Card>
                    </Grid>

                    <!-- ===== CENTER COLUMN: nav → map → telemetry → LIVE PACKET STREAM ===== -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Nav strip -->
                        <Border Grid.Row="0" CornerRadius="18" Background="{StaticResource PanelGlass}"
                                BorderBrush="{StaticResource Stroke}" BorderThickness="1" Margin="0,0,0,14" ClipToBounds="True">
                            <Grid>
                                <!-- Mac NavStrip order: [turn glyph] | distance + subtitle | (far right) flag + miles-left -->
                                <Grid Margin="18,11">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="#246FD3FF" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding NavTurnGlyph}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource Ice}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding NavDistanceText}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                        <TextBlock Text="{Binding NavSubtitle}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Dim}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Orientation="Horizontal" Margin="16,0,0,0">
                                        <TextBlock Text="🏁" FontFamily="Segoe UI Emoji" FontSize="13" Foreground="{StaticResource Dim}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding NavMilesLeftText}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <!-- green progress underline at the bottom edge -->
                                <ProgressBar VerticalAlignment="Bottom" Height="2" Minimum="0" Maximum="100"
                                             Value="{Binding RoutePercent, Mode=OneWay}" Foreground="{StaticResource Green}"
                                             Background="Transparent" BorderThickness="0" />
                            </Grid>
                        </Border>

                        <!-- Map (subtle bezel + an ice accent tab top-left) -->
                        <Border Grid.Row="1" CornerRadius="18" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                ClipToBounds="True" Margin="0,0,0,14">
                            <Grid>
                                <ctl:OsmTileMap />
                                <!-- ice accent tab (matches the Card accent-bar language) -->
                                <Border Width="36" Height="4" CornerRadius="2" Background="{StaticResource Ice}" Opacity="0.85"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,0,0,0" />
                                <ctl:CompassRose HeadingDeg="{Binding HeadingDeg}" Cardinal="{Binding Cardinal}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,16" />
                            </Grid>
                        </Border>

                        <!-- Telemetry dock -->
                        <UniformGrid Grid.Row="2" Columns="6" Margin="0,0,0,14">
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#246FD3FF" Margin="0,0,6,0">
                                            <TextBlock Text="◎" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{StaticResource Ice}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="ODOMETER" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding OdometerText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                        <TextBlock Text=" mi" FontSize="12" Foreground="{StaticResource Dim}" VerticalAlignment="Bottom" Margin="0,0,0,3" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#243E7BFA" Margin="0,0,6,0">
                                            <TextBlock Text="⇄" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{StaticResource Blue}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="TRIP" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding TripText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                        <TextBlock Text=" mi" FontSize="12" Foreground="{StaticResource Dim}" VerticalAlignment="Bottom" Margin="0,0,0,3" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#243E7BFA" Margin="0,0,6,0">
                                            <TextBlock Text="◷" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{StaticResource Blue}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="ENG HRS" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding EngineHoursText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                        <TextBlock Text=" h" FontSize="12" Foreground="{StaticResource Dim}" VerticalAlignment="Bottom" Margin="0,0,0,3" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#246FD3FF" Margin="0,0,6,0">
                                            <TextBlock Text="➤" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{StaticResource Ice}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="HEADING" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding HeadingText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Text}" />
                                        <TextBlock Text="°" FontSize="12" Foreground="{StaticResource Dim}" VerticalAlignment="Bottom" Margin="0,0,0,3" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18" Margin="0,0,12,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#2432D74B" Margin="0,0,6,0">
                                            <TextBlock Text="≋" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{Binding SatsBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="SATS" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding SatellitesText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold"
                                               Foreground="{Binding SatsBrush}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource GlassPanel}" Padding="16,18">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="18" Height="18" CornerRadius="5" Background="#2432D74B" Margin="0,0,6,0">
                                            <TextBlock Text="◉" FontFamily="Segoe UI Symbol" FontSize="10" Foreground="{Binding EcmBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="ECM" Style="{StaticResource Sec}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding EcmText}" FontFamily="{StaticResource Mono}" FontSize="24" FontWeight="Bold"
                                               Foreground="{Binding EcmBrush}" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- ===== LIVE PACKET STREAM (centre column only, fixed height) ===== -->
                        <Border Grid.Row="3" Height="184" Style="{StaticResource GlassPanel}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="LIVE PACKET STREAM" Style="{StaticResource Sec}" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding LogCountText}" FontFamily="{StaticResource Mono}" FontSize="10"
                                                   Foreground="{StaticResource Dim}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <Button Content="EXPORT" Style="{StaticResource NeonButton}" Padding="10,5" Click="ExportLog_Click" Margin="0,0,8,0" />
                                        <Button Content="CLEAR" Style="{StaticResource NeonButton}" Padding="10,5" Click="ClearLog_Click" />
                                    </StackPanel>
                                </DockPanel>
                                <ListBox x:Name="LogList" Grid.Row="1" ItemsSource="{Binding Log}" Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Focusable" Value="False" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Time}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Symbol}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{Binding Color}" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Text}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{Binding TextBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ===== RIGHT COLUMN: tach dial → FUEL → CONNECTION · SIGNAL (fills to bottom) ===== -->
                    <Grid Grid.Column="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ctl:DialGauge Grid.Row="0" Mode="Tach" Width="286" Height="286" HorizontalAlignment="Center"
                                       Fraction="{Binding TachFraction}" CenterText="{Binding RpmText}" Unit="RPM"
                                       Hot="{Binding TachHot}" Margin="0,0,0,14" />

                        <!-- FUEL — combined "DUAL TANK" panel: two cylinders + two sliders (mirrors Mac fuelPanel) -->
                        <Border Grid.Row="1" Style="{StaticResource GlassPanel}" Padding="0" Margin="0,0,0,14">
                            <Grid>
                                <!-- green accent bar along the top edge -->
                                <Border Height="2" Margin="12,0,12,0" VerticalAlignment="Top" CornerRadius="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#B332D74B" Offset="0" />
                                            <GradientStop Color="#0032D74B" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel Margin="15,13">
                                    <!-- header: fuel-pump chip + FUEL ... DUAL TANK -->
                                    <DockPanel Margin="0,0,0,12">
                                        <Border Width="23" Height="23" CornerRadius="7" Background="#2432D74B" Margin="0,0,9,0">
                                            <TextBlock Text="⛽" FontFamily="Segoe UI Emoji" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="FUEL" FontFamily="{StaticResource Rounded}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                                        <TextBlock Text="DUAL TANK" HorizontalAlignment="Right" FontSize="9.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Dim}" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <!-- body: [F1 cylinder] [F2 cylinder] | [FUEL 1 slider / FUEL 2 slider] -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                            <ctl:FuelCylinder Value="{Binding FuelPct}" Tint="{Binding FuelTintColor}" Width="46" Height="104" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding FuelPctText}" FontSize="13" FontWeight="Bold" Foreground="{Binding FuelBrush}"
                                                       HorizontalAlignment="Center" Margin="0,7,0,0" />
                                            <TextBlock Text="F1" Style="{StaticResource Sec}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                            <ctl:FuelCylinder Value="{Binding Fuel2Pct}" Tint="{Binding Fuel2TintColor}" Width="46" Height="104" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Fuel2PctText}" FontSize="13" FontWeight="Bold" Foreground="{Binding Fuel2Brush}"
                                                       HorizontalAlignment="Center" Margin="0,7,0,0" />
                                            <TextBlock Text="F2" Style="{StaticResource Sec}" HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <!-- FUEL 1 slider (green) -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="FUEL 1" FontFamily="{StaticResource Rounded}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding FuelBrush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding FuelPctText}" HorizontalAlignment="Right" FontFamily="{StaticResource Mono}"
                                                           FontSize="13" FontWeight="Bold" Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                                            </DockPanel>
                                            <Slider Minimum="0" Maximum="100" Value="{Binding FuelSlider, Mode=TwoWay}" Foreground="{Binding FuelBrush}" Margin="0,0,0,16" />
                                            <!-- FUEL 2 slider (blue) -->
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="FUEL 2" FontFamily="{StaticResource Rounded}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding Fuel2Brush}" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Fuel2PctText}" HorizontalAlignment="Right" FontFamily="{StaticResource Mono}"
                                                           FontSize="13" FontWeight="Bold" Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                                            </DockPanel>
                                            <Slider Minimum="0" Maximum="100" Value="{Binding Fuel2Slider, Mode=TwoWay}" Foreground="{Binding Fuel2Brush}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- CONNECTION · SIGNAL panel (moves here, fills to the bottom) -->
                        <ctl:Card Grid.Row="2" Title="CONNECTION · SIGNAL" Glyph="&#xE704;" Tint="{StaticResource Blue}">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock Text="SIGNAL" Style="{StaticResource Sec}" />
                                        <TextBlock Text="{Binding SignalState}" HorizontalAlignment="Right" FontSize="11"
                                                   FontWeight="Black" Foreground="{Binding SignalBrush}" />
                                    </DockPanel>
                                    <UniformGrid Columns="4" Margin="0,0,0,8">
                                        <ToggleButton Content="FULL" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}" CommandParameter="100" IsChecked="{Binding ActiveSigFull, Mode=OneWay}" Click="Signal_Click" Margin="0,0,6,0" />
                                        <ToggleButton Content="AUTO" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}" IsChecked="{Binding ActiveSigAuto, Mode=OneWay}" Click="AutoSignal_Click" Margin="0,0,6,0" />
                                        <ToggleButton Content="POOR" Style="{StaticResource NeonToggle}" Tag="{StaticResource Ice}" CommandParameter="25" IsChecked="{Binding ActiveSigPoor, Mode=OneWay}" Click="Signal_Click" Margin="0,0,6,0" />
                                        <Button x:Name="DropButton" Click="Drop_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                                    <Setter Property="Content" Value="DROP" />
                                                    <Setter Property="Foreground" Value="{StaticResource Red}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LinkDown}" Value="True">
                                                            <Setter Property="Content" Value="BACK" />
                                                            <Setter Property="Background" Value="{StaticResource Red}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource Red}" />
                                                            <Setter Property="Foreground" Value="#FF08090B" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </UniformGrid>
                                    <StackPanel Visibility="{Binding LinkDownVisible, Converter={StaticResource BoolVis}}" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding OutageCountdown}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Amber}" />
                                    </StackPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Auto-return" Width="70" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding RangeOutageText}" Width="46" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="15" Maximum="180" Value="{Binding RangeOutageSec, Mode=TwoWay}" />
                                    </DockPanel>
                                    <Border Height="1" Background="{StaticResource Stroke}" Margin="0,4,0,8" />
                                    <TextBlock Text="RAW EFFECTS" Style="{StaticResource Sec}" Margin="0,0,0,6" />
                                    <!-- Weak signal adds latency (driven by SIGNAL/AUTO), not loss. -->
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="Dup" Width="56" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DuplicateText}" Width="42" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="50" Value="{Binding DuplicatePct, Mode=TwoWay}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="Reorder" Width="56" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding OutOfOrderText}" Width="42" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="50" Value="{Binding OutOfOrderPct, Mode=TwoWay}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Interval" Width="56" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding PacketIntervalText}" Width="42" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="0.25" Maximum="3" Value="{Binding PacketIntervalSec, Mode=TwoWay}" />
                                    </DockPanel>
                                    <Border Height="1" Background="{StaticResource Stroke}" Margin="0,8,0,8" />
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock Text="STORED DUMP" Style="{StaticResource Sec}" />
                                        <TextBlock Text="{Binding StoredDumpCountText}" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="10" Foreground="{StaticResource Dim}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="Count" Width="56" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StoredDumpCount}" Width="42" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="0" Maximum="300" Value="{Binding StoredDumpCount, Mode=TwoWay}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Cadence" Width="56" Foreground="{StaticResource Dim}" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StoredDumpCadenceText}" Width="42" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                                        <Slider Minimum="0.25" Maximum="1.5" Value="{Binding StoredDumpCadenceSec, Mode=TwoWay}" />
                                    </DockPanel>
                                    <Button Click="Dump_Click" Margin="0,0,0,4">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                                <Setter Property="Content" Value="⤓ DUMP STORED" />
                                                <Setter Property="Foreground" Value="{StaticResource Blue}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDumping}" Value="True">
                                                        <Setter Property="Content" Value="⤓ DUMPING…" />
                                                        <Setter Property="Background" Value="{StaticResource Blue}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Blue}" />
                                                        <Setter Property="Foreground" Value="#FF08090B" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <TextBlock Text="≈500ms reproduces the disconnect · 1s is safe." FontSize="9" Foreground="{StaticResource Dim}" />
                                </StackPanel>
                            </ScrollViewer>
                        </ctl:Card>
                    </Grid>
                </Grid>

                <!-- ================= FOOTER ================= -->
                <DockPanel Grid.Row="2" Margin="0,16,0,0" Height="24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding FooterStatusText}" FontFamily="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource Dim}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- SCENARIO footer button + popup (mirrors Mac: scenarios are a testing tool tucked behind a footer button) -->
                        <Button x:Name="ScenarioButton2" Content="{Binding ScenarioButtonText}" Style="{StaticResource NeonButton}" Padding="10,5"
                                Foreground="{Binding ScenarioButtonBrush}" Click="Scenario_Click" Margin="0,0,8,0" />
                        <Popup x:Name="ScenarioPopup" PlacementTarget="{Binding ElementName=ScenarioButton2}" Placement="Top"
                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                    CornerRadius="14" Padding="18" Width="380" Margin="0,0,0,8">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <TextBlock Text="🎬" FontFamily="Segoe UI Emoji" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" />
                                        <TextBlock Text="SCENARIO" Style="{StaticResource Sec}" Foreground="{StaticResource Red}" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <ComboBox ItemsSource="{Binding Scenarios}" SelectedItem="{Binding SelectedScenario, Mode=TwoWay}"
                                              Height="32" Margin="0,0,0,10" FontFamily="{StaticResource Rounded}" />
                                    <!-- One button like the Mac: filled-red RUN when idle (opens the guided overlay), red-outline STOP while running -->
                                    <Button x:Name="ScenarioRunButton" Click="ScenarioToggle_Click" Margin="0,0,0,8">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource NeonButton}">
                                                <Setter Property="Content" Value="▶ RUN" />
                                                <Setter Property="Background" Value="{StaticResource Red}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource Red}" />
                                                <Setter Property="Foreground" Value="#FF08090B" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ScenarioRunning}" Value="True">
                                                        <Setter Property="Content" Value="■ STOP" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Foreground" Value="{StaticResource Red}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Red}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button x:Name="StepsButton" Style="{StaticResource NeonButton}" Foreground="{StaticResource Amber}"
                                            HorizontalContentAlignment="Stretch" Click="Steps_Click">
                                        <DockPanel>
                                            <TextBlock Text="{Binding WhatHowText}" />
                                            <TextBlock Text="⌃" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                        </DockPanel>
                                    </Button>
                                    <!-- WHAT & HOW expander (inline; toggled by the button above) -->
                                    <StackPanel x:Name="StepsExpander" Visibility="Collapsed" Margin="0,10,0,0">
                                        <TextBlock Text="{Binding SelectedScenarioTitle}" FontSize="13" FontWeight="Black" Foreground="{StaticResource Text}" Margin="0,0,0,8" />
                                        <TextBlock Text="WHAT IT DOES" Style="{StaticResource Sec}" Margin="0,0,0,3" />
                                        <TextBlock Text="{Binding SelectedScenarioExpect}" FontSize="12" Foreground="{StaticResource Text}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <Border Height="1" Background="{StaticResource Stroke}" Margin="0,0,0,10" />
                                        <TextBlock Text="📋 DO THIS IN THE APP" FontSize="10" FontWeight="Black" Foreground="{StaticResource Amber}" Margin="0,0,0,8" />
                                        <ItemsControl ItemsSource="{Binding SelectedScenarioSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontSize="13" Foreground="{StaticResource Text}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                    <TextBlock Text="{Binding RunningScenario}" FontSize="11" Foreground="{StaticResource Dim}"
                                               Margin="0,10,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Popup>

                        <Button x:Name="DtcButton" Content="{Binding DtcButtonText}" Style="{StaticResource NeonButton}" Padding="10,5"
                                Foreground="{Binding DtcButtonBrush}" Click="Dtc_Click" Margin="0,0,8,0" />
                        <Popup x:Name="DtcPopup" PlacementTarget="{Binding ElementName=DtcButton}" Placement="Top"
                               StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                    CornerRadius="14" Padding="16" Width="360" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="DIAGNOSTICS · DTC" Style="{StaticResource Sec}" Foreground="{StaticResource Amber}" Margin="0,0,0,12" />
                                    <UniformGrid Columns="4" Margin="0,0,0,10">
                                        <ToggleButton Content="P0143" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="P0143" IsChecked="{Binding FaultP0143, Mode=OneWay}" Click="Fault_Click" Margin="0,0,6,0" />
                                        <ToggleButton Content="P0217" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="P0217" IsChecked="{Binding FaultP0217, Mode=OneWay}" Click="Fault_Click" Margin="0,0,6,0" />
                                        <ToggleButton Content="C0035" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="C0035" IsChecked="{Binding FaultC0035, Mode=OneWay}" Click="Fault_Click" Margin="0,0,6,0" />
                                        <ToggleButton Content="U0101" Style="{StaticResource NeonToggle}" Tag="{StaticResource Amber}" CommandParameter="U0101" IsChecked="{Binding FaultU0101, Mode=OneWay}" Click="Fault_Click" />
                                    </UniformGrid>
                                    <DockPanel>
                                        <Button Content="🗑 CLEAR" Style="{StaticResource NeonButton}" Foreground="{StaticResource Red}" Width="96"
                                                DockPanel.Dock="Right" Click="ClearFaults_Click" />
                                        <TextBlock Text="{Binding FaultsText}" FontFamily="{StaticResource Mono}" FontSize="11"
                                                   Foreground="{StaticResource Dim}" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                        <Button Content="↻ REPLAY IGNITION" Style="{StaticResource NeonButton}" Padding="10,5" Foreground="{StaticResource Dim}" Click="ReplayIgnition_Click" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Viewbox>

        <!-- ================= IGNITION OVERLAY ================= -->
        <Grid x:Name="Ignition" Background="#FF08090B" Visibility="{Binding IgnitionVisible, Converter={StaticResource BoolVis}}"
              MouseDown="Ignition_MouseDown">
            <Ellipse Opacity="0.14" HorizontalAlignment="Center" VerticalAlignment="Center" Width="1280" Height="1280">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#E2122B" Offset="0" />
                        <GradientStop Color="#00E2122B" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Cold: START button -->
            <StackPanel Visibility="{Binding IsCold, Converter={StaticResource BoolVis}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Width="156" Height="156" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Start_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="breathe" ScaleX="1" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Ellipse Width="156" Height="156" Stroke="#66E2122B" StrokeThickness="2" />
                                <Ellipse Width="132" Height="132" Fill="#1AE2122B" Stroke="{StaticResource Red}" StrokeThickness="3">
                                    <Ellipse.Effect>
                                        <DropShadowEffect x:Name="bglow" Color="#E2122B" BlurRadius="10" ShadowDepth="0" Opacity="0.8" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⏻" FontSize="40" FontWeight="Bold" Foreground="{StaticResource Red}" HorizontalAlignment="Center" />
                                    <TextBlock Text="START" FontSize="15" FontWeight="Black" Foreground="{StaticResource Text}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="breathe" Storyboard.TargetProperty="ScaleX" From="1.0" To="1.04" Duration="0:0:1.6">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="breathe" Storyboard.TargetProperty="ScaleY" From="1.0" To="1.04" Duration="0:0:1.6">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="bglow" Storyboard.TargetProperty="BlurRadius" From="10" To="26" Duration="0:0:1.6">
                                                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="PRESS TO INITIALIZE" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Dim}"
                           HorizontalAlignment="Center" Margin="0,24,0,0" />
            </StackPanel>

            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,52,0,0"
                        Visibility="{Binding IsCold, Converter={StaticResource BoolVis}}">
                <TextBlock Text="MATRACK TRUCK SIMULATOR" FontSize="15" FontWeight="Black" Foreground="#66F4F6FA" HorizontalAlignment="Center" />
                <TextBlock Text="Virtual J1939 / MT tracker" FontSize="11" FontWeight="Medium" Foreground="#8C868E9C" HorizontalAlignment="Center" Margin="0,6,0,0" />
            </StackPanel>

            <!-- Sweep stage -->
            <StackPanel Visibility="{Binding SweepVisible, Converter={StaticResource BoolVis}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ctl:DialGauge Mode="Speed" Width="240" Height="240" Margin="0,0,45,0"
                                   Fraction="{Binding SweepFraction}" CenterText="{Binding SweepSpeedText}" Unit="KM/H" />
                    <ctl:DialGauge Mode="Tach" Width="240" Height="240" Margin="45,0,0,0"
                                   Fraction="{Binding SweepFraction}" CenterText="{Binding SweepRpmText}" Unit="RPM" />
                </StackPanel>
                <TextBlock Text="SYSTEMS NOMINAL" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Green}"
                           HorizontalAlignment="Center" Margin="0,34,0,0"
                           Visibility="{Binding SystemsNominalVisible, Converter={StaticResource BoolVis}}" />
            </StackPanel>
        </Grid>

        <!-- ================= GUIDED WALKTHROUGH OVERLAY (centered, dim full-window scrim) ================= -->
        <Grid x:Name="GuidedOverlay" Background="#94000000" Visibility="Collapsed" MouseDown="GuidedBackdrop_MouseDown">
            <ContentControl x:Name="GuidedHost" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>
