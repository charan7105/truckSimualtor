<Window x:Class="MatrackSim.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Matrack Truck Sim" Height="900" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <!-- Functional operator-panel layout. Left = control panels (mirror ControlsDrawer.swift),
         Right = live packet stream. Gauges + route map are TODO (see notes in code-behind). -->
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Header / connection status ===== -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="11" Height="11" Margin="0,0,8,0"
                             Fill="{Binding StatusColor}" />
                    <TextBlock Text="MATRACK TRUCK SIM" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource Text}" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}" Margin="16,0,0,0"
                           VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                           Foreground="{Binding StatusColor}" />
                <TextBlock Grid.Column="2" Text="{Binding Vin}" VerticalAlignment="Center"
                           FontFamily="Consolas" FontSize="11" Foreground="{StaticResource Dim}" />
            </Grid>
        </Border>

        <!-- ===== Left: scrollable control stack ===== -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      Margin="0,0,7,0">
            <StackPanel>

                <!-- TODO: instrument-cluster gauges (twin Ø360 speed/RPM dials) — not ported yet. -->
                <!-- TODO: route map view — not ported yet. -->

                <!-- ===== DRIVE panel ===== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DRIVE" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource Green}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ToggleButton Content="ENGINE" IsChecked="{Binding IgnitionOn}"
                                          Width="120" Height="34" Margin="0,0,8,0"
                                          Foreground="{StaticResource Text}" />
                            <ToggleButton Content="AUTO" IsChecked="{Binding AutoDrive}"
                                          Width="120" Height="34"
                                          Foreground="{StaticResource Text}" />
                        </StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="MODE" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="{Binding ModeText}" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" Foreground="{StaticResource Ice}" />
                        </DockPanel>

                        <TextBlock Text="QUICK SET · KM/H" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="STOP" Style="{StaticResource NeonButton}" Width="60" Tag="0"
                                    Click="SpeedPreset_Click" Foreground="{StaticResource Red}" />
                            <Button Content="60" Style="{StaticResource NeonButton}" Width="60" Tag="60"
                                    Click="SpeedPreset_Click" />
                            <Button Content="90" Style="{StaticResource NeonButton}" Width="60" Tag="90"
                                    Click="SpeedPreset_Click" />
                            <Button Content="110" Style="{StaticResource NeonButton}" Width="60" Tag="110"
                                    Click="SpeedPreset_Click" />
                        </StackPanel>

                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="SPEED" Style="{StaticResource SectionLabel}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding SpeedKmhText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource Ice}" />
                                <TextBlock Text=" km/h" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource Dim}" VerticalAlignment="Bottom"
                                           Margin="0,0,0,3" />
                            </StackPanel>
                        </DockPanel>
                        <Slider Minimum="0" Maximum="130" Value="{Binding SpeedKmh, Mode=TwoWay}" />

                        <TextBlock Text="SIM SPEED · MAP PACE" Style="{StaticResource SectionLabel}" Margin="0,8,0,6" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="1×" Style="{StaticResource NeonButton}" Width="48" Tag="1"
                                    Click="TimeScale_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="5×" Style="{StaticResource NeonButton}" Width="48" Tag="5"
                                    Click="TimeScale_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="10×" Style="{StaticResource NeonButton}" Width="48" Tag="10"
                                    Click="TimeScale_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="25×" Style="{StaticResource NeonButton}" Width="48" Tag="25"
                                    Click="TimeScale_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="30×" Style="{StaticResource NeonButton}" Width="48" Tag="30"
                                    Click="TimeScale_Click" Foreground="{StaticResource Amber}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== ROUTE panel (DRIVE MY DAY lives here) ===== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="ROUTE · NAVIGATION" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource Ice}" Margin="0,0,0,10" />
                        <!-- TODO: route map render + From/To geocoding — not ported yet. -->
                        <TextBlock Text="{Binding RouteInfo}" FontSize="11" Foreground="{StaticResource Dim}"
                                   TextWrapping="Wrap" Margin="0,0,0,8" />
                        <Button x:Name="DayButton" Content="DRIVE MY DAY" Style="{StaticResource NeonButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,6"
                                Foreground="{StaticResource Amber}" Click="DriveMyDay_Click" />
                        <TextBlock Text="Full state-crossing day at 30× · IFTA mileage + speeding/idle events. (HOS hour-clocks run real-time.)"
                                   FontSize="9" Foreground="{StaticResource Dim}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ===== SCENARIO panel ===== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SCENARIO" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource Red}" Margin="0,0,0,10" />
                        <ComboBox x:Name="ScenarioCombo" ItemsSource="{Binding Scenarios}"
                                  SelectedItem="{Binding SelectedScenario, Mode=TwoWay}"
                                  Margin="0,0,0,8" Height="30" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="RUN" Style="{StaticResource NeonButton}" Width="120"
                                    Foreground="{StaticResource Red}" Click="RunScenario_Click" />
                            <Button Content="STOP" Style="{StaticResource NeonButton}" Width="120"
                                    Foreground="{StaticResource Red}" Click="StopScenario_Click" />
                        </StackPanel>
                        <TextBlock Text="{Binding RunningScenario}" FontSize="11" Foreground="{StaticResource Dim}"
                                   Margin="0,8,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- ===== CONNECTION · SIGNAL panel (F1 + F2) ===== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="CONNECTION · SIGNAL" Style="{StaticResource SectionLabel}"
                                       Foreground="{StaticResource Blue}" />
                            <TextBlock Text="{Binding SignalState}" HorizontalAlignment="Right"
                                       FontSize="11" FontWeight="Bold" Foreground="{Binding SignalColor}" />
                        </DockPanel>

                        <!-- F1 — signal presets + DROP/forceDisconnect -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="FULL" Style="{StaticResource NeonButton}" Width="62" Tag="100"
                                    Click="Signal_Click" />
                            <Button Content="WEAK" Style="{StaticResource NeonButton}" Width="62" Tag="60"
                                    Click="Signal_Click" />
                            <Button Content="POOR" Style="{StaticResource NeonButton}" Width="62" Tag="25"
                                    Click="Signal_Click" />
                            <Button x:Name="DropButton" Content="DROP" Style="{StaticResource NeonButton}"
                                    Width="62" Foreground="{StaticResource Red}" Click="Drop_Click" />
                        </StackPanel>
                        <TextBlock Text="{Binding OutageCountdown}" FontSize="11" Foreground="{StaticResource Amber}"
                                   Margin="0,0,0,6" />

                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Auto-return" Width="70" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding RangeOutageText}" Width="46" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="15" Maximum="180" Value="{Binding RangeOutageSec, Mode=TwoWay}" />
                        </DockPanel>

                        <Border Height="1" Background="{StaticResource Stroke}" Margin="0,4,0,8" />

                        <!-- F2 — stored-packet dump -->
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="STORED DUMP" Style="{StaticResource SectionLabel}" />
                            <TextBlock Text="{Binding StoredDumpCountText}" HorizontalAlignment="Right"
                                       FontFamily="Consolas" FontSize="10" Foreground="{StaticResource Dim}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Count" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding StoredDumpCount}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0" Maximum="300" Value="{Binding StoredDumpCount, Mode=TwoWay}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Cadence" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding StoredDumpCadenceText}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0.25" Maximum="1.5" Value="{Binding StoredDumpCadenceSec, Mode=TwoWay}" />
                        </DockPanel>
                        <Button x:Name="DumpButton" Content="DUMP STORED" Style="{StaticResource NeonButton}"
                                HorizontalAlignment="Stretch" Foreground="{StaticResource Blue}"
                                Click="Dump_Click" Margin="0,0,0,4" />
                        <TextBlock Text="≈500ms reproduces the disconnect · 1s is safe."
                                   FontSize="9" Foreground="{StaticResource Dim}" />

                        <Border Height="1" Background="{StaticResource Stroke}" Margin="0,8,0,8" />

                        <!-- Raw transport effects (advanced) -->
                        <TextBlock Text="RAW EFFECTS" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Loss" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding PacketLossText}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0" Maximum="50" Value="{Binding PacketLossPct, Mode=TwoWay}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Dup" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding DuplicateText}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0" Maximum="50" Value="{Binding DuplicatePct, Mode=TwoWay}" />
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Reorder" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding OutOfOrderText}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0" Maximum="50" Value="{Binding OutOfOrderPct, Mode=TwoWay}" />
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Interval" Width="56" Foreground="{StaticResource Dim}" FontSize="11" />
                            <TextBlock Text="{Binding PacketIntervalText}" Width="42" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" FontFamily="Consolas" FontSize="11"
                                       Foreground="{StaticResource Ice}" />
                            <Slider Minimum="0.25" Maximum="3" Value="{Binding PacketIntervalSec, Mode=TwoWay}" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- ===== DIAGNOSTICS · DTC panel ===== -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DIAGNOSTICS · DTC" Style="{StaticResource SectionLabel}"
                                   Foreground="{StaticResource Amber}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="P0143" Style="{StaticResource NeonButton}" Width="68" Tag="P0143"
                                    Click="Fault_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="P0217" Style="{StaticResource NeonButton}" Width="68" Tag="P0217"
                                    Click="Fault_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="C0035" Style="{StaticResource NeonButton}" Width="68" Tag="C0035"
                                    Click="Fault_Click" Foreground="{StaticResource Amber}" />
                            <Button Content="U0101" Style="{StaticResource NeonButton}" Width="68" Tag="U0101"
                                    Click="Fault_Click" Foreground="{StaticResource Amber}" />
                        </StackPanel>
                        <DockPanel>
                            <Button Content="CLEAR" Style="{StaticResource NeonButton}" Width="96"
                                    DockPanel.Dock="Right" Foreground="{StaticResource Red}"
                                    Click="ClearFaults_Click" />
                            <TextBlock Text="{Binding FaultsText}" FontSize="11" FontFamily="Consolas"
                                       Foreground="{StaticResource Dim}" VerticalAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== Right: live packet stream ===== -->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="7,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="LIVE PACKET STREAM" Style="{StaticResource SectionLabel}"
                               Foreground="{StaticResource Ice}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding LogCountText}" FontFamily="Consolas" FontSize="10"
                                   Foreground="{StaticResource Dim}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Button Content="CLEAR" Style="{StaticResource NeonButton}" Width="70"
                                Click="ClearLog_Click" />
                    </StackPanel>
                </DockPanel>
                <ListBox x:Name="LogList" Grid.Row="1" ItemsSource="{Binding Log}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Time}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource Dim}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Symbol}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{Binding Color}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Text}" FontFamily="Consolas" FontSize="11"
                                           Foreground="{StaticResource Text}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
